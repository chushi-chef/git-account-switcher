{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Git Account Switcher",
  "version": "1.0.0",
  "identifier": "local.git-account-switcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Git Account Switcher",
        "width": 760,
        "height": 580,
        "minWidth": 750,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Safely switch local GitHub identities.",
    "longDescription": "A local desktop tool for switching Git commit identity, SSH host aliases, and repository remotes without deleting existing GitHub credentials.",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENGMUNCNDg5RkRFQzc3RTMKUldUamQrejlpYlFjejdweE41U0tsUlV3MWg1T3VjWmpocHdaZjZMMnZJdW9IdFEwTU5Ib0c1d2sK",
      "endpoints": [
        "https://github.com/FuGuiZh/git-account-switcher/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
