{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Git Account Switcher",
  "version": "0.1.0",
  "identifier": "local.git-account-switcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Git Account Switcher",
        "width": 760,
        "height": 540,
        "minWidth": 620,
        "minHeight": 460,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Safely switch local GitHub identities.",
    "longDescription": "A local desktop tool for switching Git commit identity, SSH host aliases, and repository remotes without deleting existing GitHub credentials.",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
